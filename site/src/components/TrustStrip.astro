---
import { site } from '@/data/site';
const stats = [
  { n: `${site.reviews.total}+`, l: 'Five-star reviews' },
  { n: '5.0★', l: 'Across every platform' },
  { n: '24/7', l: 'Emergency service' },
  { n: `${site.serviceRadiusMiles}mi`, l: 'Mobile service radius' },
];
---
<div class="trust">
  {stats.map((s) => (
    <div class="trust__item">
      <div class="trust__n">{s.n}</div>
      <div class="trust__l">{s.l}</div>
    </div>
  ))}
</div>

<style>
  .trust{ display:grid; grid-template-columns:repeat(4,1fr); gap:1px; background:var(--line);
    border:1px solid var(--line); border-radius:var(--radius); overflow:hidden; }
  .trust__item{ background:#fff; padding:1.2rem 1rem; text-align:center; }
  .trust__n{ font-size:clamp(1.5rem,3vw,2rem); font-weight:800; color:var(--navy); letter-spacing:-.02em; line-height:1; }
  .trust__l{ font-size:.82rem; color:var(--muted); margin-top:.35rem; }
  @media (max-width:560px){ .trust{ grid-template-columns:repeat(2,1fr); } }
</style>
