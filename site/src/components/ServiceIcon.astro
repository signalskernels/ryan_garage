---
// Simple inline line-icons keyed by service. Stroke inherits currentColor.
interface Props { name: string; size?: number; }
const { name, size = 28 } = Astro.props;
const paths: Record<string, string> = {
  spring: '<path d="M7 4h10M7 4v2.5L17 9 7 11.5 17 14 7 16.5 17 19v1H7"/>',
  opener: '<rect x="3" y="4" width="18" height="6" rx="1"/><path d="M12 10v5"/><circle cx="12" cy="18" r="2.4"/>',
  cable: '<path d="M6 3v4a6 6 0 0 0 12 0V3"/><path d="M12 13v8"/><path d="M9 21h6"/>',
  roller: '<circle cx="7" cy="12" r="3"/><circle cx="17" cy="12" r="3"/><path d="M10 12h4"/>',
  install: '<path d="M3 21V8l9-5 9 5v13"/><path d="M3 12h18M3 16.5h18M12 8v13"/>',
  replace: '<path d="M21 12a9 9 0 1 1-3-6.7"/><path d="M21 3v5h-5"/>',
  maintenance: '<path d="M14.7 6.3a4 4 0 0 0-5.4 5.4L3 18v3h3l6.3-6.3a4 4 0 0 0 5.4-5.4l-2.5 2.5-2.5-.7-.7-2.5 2.4-2.8Z"/>',
  keypad: '<rect x="5" y="3" width="14" height="18" rx="2"/><circle cx="9" cy="8" r=".6"/><circle cx="12" cy="8" r=".6"/><circle cx="15" cy="8" r=".6"/><circle cx="9" cy="12" r=".6"/><circle cx="12" cy="12" r=".6"/><circle cx="15" cy="12" r=".6"/>',
};
const d = paths[name] ?? paths.maintenance;
---
<svg width={size} height={size} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={d} />
