---
import type { Review } from '@/data/reviews';
interface Props { review: Review; }
const { review } = Astro.props;
---
<figure class="rv card">
  <div class="rv__top">
    <span class="stars" aria-label={`${review.rating} out of 5 stars`}>★★★★★</span>
    <span class="rv__src">{review.source}</span>
  </div>
  <blockquote class="rv__text">{review.text}</blockquote>
  <figcaption class="rv__by">
    <span class="rv__avatar" aria-hidden="true">{review.author.trim().charAt(0).toUpperCase()}</span>
    <span>
      <b>{review.author}</b>
      {review.tag && <small>{review.tag}</small>}
    </span>
  </figcaption>
</figure>

<style>
  .rv{ display:flex; flex-direction:column; height:100%; }
  .rv .card__body{ display:flex; flex-direction:column; }
  .rv{ padding:1.4rem 1.4rem 1.2rem; }
  .rv__top{ display:flex; align-items:center; justify-content:space-between; margin-bottom:.6rem; }
  .rv__src{ font-size:.72rem; font-weight:700; text-transform:uppercase; letter-spacing:.06em; color:var(--muted); }
  .rv__text{ margin:0 0 1rem; font-size:.98rem; color:var(--body); line-height:1.6; flex:1; }
  .rv__by{ display:flex; align-items:center; gap:.7rem; border-top:1px solid var(--line-2); padding-top:.9rem; }
  .rv__avatar{ width:38px; height:38px; border-radius:50%; background:var(--navy); color:#fff; font-weight:800;
    display:flex; align-items:center; justify-content:center; flex:none; }
  .rv__by b{ display:block; color:var(--ink); font-size:.95rem; }
  .rv__by small{ color:var(--muted); font-size:.78rem; }
</style>
