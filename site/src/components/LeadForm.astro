---
import { services } from '@/data/services';
interface Props {
  formName?: string;
  heading?: string;
  intro?: string;
  cta?: string;
  /** show preferred date/time fields (service-request flow) */
  scheduling?: boolean;
}
const {
  formName = 'service-request',
  heading = 'Request your service',
  intro = 'Tell us what’s going on and the best time to reach you. We’ll confirm your appointment fast — usually the same day.',
  cta = 'Send my request',
  scheduling = true,
} = Astro.props;
---
<div class="lf card" data-lead-form>
  <div class="lf__head">
    <h3>{heading}</h3>
    <p>{intro}</p>
  </div>

  <!-- Netlify Forms: static markup is detected at build; AJAX submit below
       works on both Netlify (captures) and the preview (no-op success). -->
  <form
    name={formName}
    method="POST"
    data-netlify="true"
    netlify-honeypot="bot-field"
    class="lf__form"
    data-form-name={formName}
  >
    <input type="hidden" name="form-name" value={formName} />
    <p class="lf__hp"><label>Don’t fill this out: <input name="bot-field" /></label></p>

    <div class="lf__row">
      <label class="field">
        <span>Name</span>
        <input class="input" type="text" name="name" autocomplete="name" required />
      </label>
      <label class="field">
        <span>Phone</span>
        <input class="input" type="tel" name="phone" autocomplete="tel" required />
      </label>
    </div>

    <div class="lf__row">
      <label class="field">
        <span>Email <em>(optional)</em></span>
        <input class="input" type="email" name="email" autocomplete="email" />
      </label>
      <label class="field">
        <span>City / ZIP</span>
        <input class="input" type="text" name="location" placeholder="e.g. Huntley, 60142" />
      </label>
    </div>

    <label class="field">
      <span>What do you need?</span>
      <select class="select" name="service">
        <option value="">Select a service…</option>
        {services.map((s) => <option value={s.title}>{s.title}</option>)}
        <option value="Not sure / something else">Not sure / something else</option>
      </select>
    </label>

    {scheduling && (
      <div class="lf__row">
        <label class="field">
          <span>Preferred date</span>
          <input class="input" type="date" name="preferred_date" />
        </label>
        <label class="field">
          <span>Preferred time</span>
          <select class="select" name="preferred_time">
            <option value="">Any time</option>
            <option>Morning (8am–12pm)</option>
            <option>Afternoon (12pm–4pm)</option>
            <option>Evening (4pm–8pm)</option>
            <option>ASAP / Emergency</option>
          </select>
        </label>
      </div>
    )}

    <label class="field">
      <span>Tell us about your door <em>(optional)</em></span>
      <textarea class="textarea" name="details" placeholder="Make/age of door, what’s happening, any photos you can describe…"></textarea>
    </label>

    <button type="submit" class="btn btn--lg btn--block">{cta}</button>
    <p class="lf__fine">Or call us anytime at <a href="tel:+12247700587"><b>(224) 770-0587</b></a>. No obligation — we’ll give you an honest assessment.</p>
  </form>

  <div class="lf__success" data-lead-success hidden>
    <div class="lf__check" aria-hidden="true">✓</div>
    <h3>Thanks — we’ve got it!</h3>
    <p>Your request is in. We’ll reach out shortly to confirm your appointment. Need us right now? Call <a href="tel:+12247700587"><b>(224) 770-0587</b></a>.</p>
  </div>
</div>

<style>
  .lf{ padding:clamp(20px,2.6vw,30px); }
  .lf__head h3{ margin-bottom:.35rem; }
  .lf__head p{ color:var(--muted); font-size:.95rem; margin-bottom:1.2rem; }
  .lf__row{ display:grid; grid-template-columns:1fr 1fr; gap:0 1rem; }
  @media (max-width:520px){ .lf__row{ grid-template-columns:1fr; } }
  .field span em{ color:var(--muted); font-weight:400; font-style:normal; }
  .lf__hp{ position:absolute; left:-9999px; }
  .lf__fine{ font-size:.82rem; color:var(--muted); margin:.9rem 0 0; text-align:center; }
  .lf__success{ text-align:center; padding:1.5rem .5rem; }
  .lf__check{ width:56px; height:56px; border-radius:50%; background:var(--gold); color:var(--navy-900);
    font-size:1.8rem; font-weight:800; display:flex; align-items:center; justify-content:center; margin:0 auto 1rem; }
</style>

<script>
  document.querySelectorAll<HTMLElement>('[data-lead-form]').forEach((wrap) => {
    const form = wrap.querySelector<HTMLFormElement>('form');
    const success = wrap.querySelector<HTMLElement>('[data-lead-success]');
    if (!form) return;
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const data = new FormData(form);
      const body = new URLSearchParams();
      data.forEach((v, k) => body.append(k, String(v)));
      const btn = form.querySelector<HTMLButtonElement>('button[type=submit]');
      if (btn) { btn.disabled = true; btn.textContent = 'Sending…'; }
      try {
        // Posts to "/" — Netlify captures AJAX form submissions this way.
        await fetch('/', { method: 'POST', headers: { 'Content-Type': 'application/x-www-form-urlencoded' }, body: body.toString() });
      } catch (_) { /* preview has no form backend — still show success UX */ }
      form.hidden = true;
      if (success) { success.hidden = false; success.scrollIntoView({ behavior: 'smooth', block: 'center' }); }
    });
  });
</script>
