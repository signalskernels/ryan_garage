---
import { site } from '@/data/site';
interface Props { title?: string; text?: string; }
const {
  title = 'Garage door trouble? We can help today.',
  text = 'Call now for fast, friendly service — or send a request and we’ll get right back to you.',
} = Astro.props;
---
<section class="section section--tight cta">
  <div class="wrap cta__in">
    <div>
      <h2>{title}</h2>
      <p class="lead">{text}</p>
    </div>
    <div class="cta__btns">
      <a href={site.phoneHref} class="btn btn--lg">Call {site.phone}</a>
      <a href="/book" class="btn btn--lg btn--ghost">Request Service</a>
    </div>
  </div>
</section>

<style>
  .cta{ background:linear-gradient(135deg,var(--navy) 0%, var(--navy-900) 100%); color:#dbe6f5; }
  .cta__in{ display:flex; align-items:center; justify-content:space-between; gap:2rem; flex-wrap:wrap; }
  .cta h2{ color:#fff; }
  .cta .lead{ color:#aec3e0; margin:.5rem 0 0; }
  .cta__btns{ display:flex; gap:.8rem; flex-wrap:wrap; }
  @media (max-width:760px){ .cta__btns .btn{ flex:1; } }
</style>
