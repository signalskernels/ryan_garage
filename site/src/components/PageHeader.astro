---
import { site } from '@/data/site';
interface Props {
  title: string;
  subtitle?: string;
  crumbs?: { label: string; href?: string }[];
  showCall?: boolean;
}
const { title, subtitle, crumbs = [], showCall = true } = Astro.props;
---
<section class="ph section--navy">
  <div class="wrap">
    <nav class="ph__crumbs" aria-label="Breadcrumb">
      <a href="/">Home</a>
      {crumbs.map((c) => (
        <>
          <span aria-hidden="true">›</span>
          {c.href ? <a href={c.href}>{c.label}</a> : <span class="ph__cur">{c.label}</span>}
        </>
      ))}
    </nav>
    <div class="ph__row">
      <div>
        <h1>{title}</h1>
        {subtitle && <p class="lead ph__sub">{subtitle}</p>}
      </div>
      {showCall && (
        <a href={site.phoneHref} class="btn btn--lg ph__call">Call {site.phone}</a>
      )}
    </div>
  </div>
</section>

<style>
  .ph{ padding-block:clamp(34px,5vw,56px); }
  .ph__crumbs{ font-size:.85rem; color:#9fb4d2; margin-bottom:1rem; display:flex; gap:.5rem; align-items:center; flex-wrap:wrap; }
  .ph__crumbs a{ color:#cfe0f6; }
  .ph__crumbs a:hover{ color:#fff; }
  .ph__cur{ color:#fff; font-weight:600; }
  .ph__row{ display:flex; align-items:center; justify-content:space-between; gap:1.5rem; flex-wrap:wrap; }
  .ph__sub{ margin:.6rem 0 0; max-width:62ch; }
  .ph__call{ flex:none; }
  @media (max-width:680px){ .ph__call{ display:none; } }
</style>
