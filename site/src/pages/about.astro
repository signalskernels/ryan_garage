---
import { Image } from 'astro:assets';
import Base from '@/layouts/Base.astro';
import PageHeader from '@/components/PageHeader.astro';
import CtaBand from '@/components/CtaBand.astro';
import TrustStrip from '@/components/TrustStrip.astro';
import { photo } from '@/lib/photos';
import { page } from '@/lib/pages';

const c = page('about');
---
<Base title={c.meta.title} description={c.meta.description}>
  <PageHeader
    title={c.header.title}
    subtitle={c.header.subtitle}
    crumbs={[{ label: c.header.crumb }]}
  />

  <section class="section">
    <div class="wrap about">
      <div class="prose about__copy">
        <h2>{c.intro.heading}</h2>
        {c.intro.paragraphs.map((p: string) => <p set:html={p} />)}
      </div>
      <div class="about__media">
        <Image src={photo(c.image.src)} alt={c.image.alt} widths={[420, 640]} sizes="(max-width:800px) 100vw, 420px" />
        <div class="about__card card">
          <div class="about__card-n">{c.stat.number}</div>
          <p>{c.stat.text}</p>
        </div>
      </div>
    </div>
  </section>

  <TrustStrip />

  <section class="section section--surface">
    <div class="wrap">
      <div class="sec-head center">
        <p class="eyebrow">{c.values.eyebrow}</p>
        <h2>{c.values.heading}</h2>
      </div>
      <div class="grid cols-4">
        {c.values.items.map((v: { t: string; d: string }) => (
          <div class="val card">
            <h3>{v.t}</h3>
            <p>{v.d}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <CtaBand title={c.cta.title} />
</Base>

<style>
  .about{ display:grid; grid-template-columns:1.1fr .9fr; gap:clamp(28px,4vw,52px); align-items:start; }
  @media (max-width:860px){ .about{ grid-template-columns:1fr; } }
  .about__media{ position:relative; }
  .about__media :global(img){ width:100%; border-radius:var(--radius-lg); box-shadow:var(--shadow); }
  .about__card{ position:absolute; right:-12px; bottom:-18px; max-width:200px; padding:1rem 1.2rem; background:var(--navy); color:#cfe0f6; }
  .about__card-n{ font-size:1.6rem; font-weight:800; color:#fff; line-height:1; }
  .about__card p{ font-size:.82rem; margin:.3rem 0 0; }
  .sec-head{ max-width:60ch; } .sec-head.center{ margin-inline:auto; }
  .val{ padding:1.3rem; }
  .val h3{ font-size:1.08rem; margin-bottom:.3rem; }
  .val p{ font-size:.92rem; color:var(--muted); margin:0; }
</style>
