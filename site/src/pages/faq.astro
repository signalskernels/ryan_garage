---
import Base from '@/layouts/Base.astro';
import PageHeader from '@/components/PageHeader.astro';
import CtaBand from '@/components/CtaBand.astro';
import { faqs } from '@/data/faqs';
import { site } from '@/data/site';
import { page } from '@/lib/pages';

const c = page('faq');
const jsonLd = [{
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })),
}];
---
<Base title={c.meta.title} description={c.meta.description} jsonLd={jsonLd}>
  <PageHeader
    title={c.header.title}
    subtitle={c.header.subtitle}
    crumbs={[{ label: c.header.crumb }]}
  />

  <section class="section">
    <div class="wrap measure faq" style="margin-inline:auto;">
      <div class="faq__search">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><circle cx="11" cy="11" r="7"/><path d="M21 21l-4.3-4.3"/></svg>
        <input type="search" class="input" placeholder={c.searchPlaceholder} data-faq-search aria-label="Search frequently asked questions" />
      </div>
      <p class="faq__empty" data-faq-empty hidden set:html={c.emptyHtml}></p>
      {faqs.map((f, i) => (
        <details class="faq__item" open={i === 0}>
          <summary>
            <span>{f.q}</span>
            <span class="faq__chev" aria-hidden="true">+</span>
          </summary>
          <div class="faq__a"><p>{f.a}</p></div>
        </details>
      ))}
      <div class="faq__cta card">
        <div>
          <h3>{c.cta.heading}</h3>
          <p>{c.cta.text}</p>
        </div>
        <a href={site.phoneHref} class="btn btn--lg">{c.cta.callLabel}</a>
      </div>
    </div>
  </section>

  <CtaBand />
</Base>

<style>
  .faq__item{ border:1px solid var(--line); border-radius:var(--radius-sm); margin-bottom:.7rem; background:#fff; overflow:hidden; }
  .faq__item[open]{ border-color:#cdd6e4; box-shadow:var(--shadow-sm); }
  .faq__item summary{ list-style:none; cursor:pointer; display:flex; align-items:center; justify-content:space-between; gap:1rem;
    padding:1.1rem 1.3rem; font-weight:700; color:var(--ink); font-size:1.04rem; }
  .faq__item summary::-webkit-details-marker{ display:none; }
  .faq__chev{ flex:none; width:26px; height:26px; border-radius:50%; background:var(--surface-2); color:var(--navy);
    display:flex; align-items:center; justify-content:center; font-size:1.2rem; font-weight:700; transition:transform .2s ease; }
  .faq__item[open] .faq__chev{ transform:rotate(45deg); background:var(--navy); color:#fff; }
  .faq__a{ padding:0 1.3rem 1.2rem; color:var(--body); }
  .faq__a p{ margin:0; }
  .faq__cta{ display:flex; align-items:center; justify-content:space-between; gap:1.5rem; padding:1.5rem; margin-top:1.6rem; flex-wrap:wrap; }
  .faq__cta h3{ margin-bottom:.2rem; }
  .faq__cta p{ margin:0; color:var(--muted); }

  .faq__search{ position:relative; margin-bottom:1.2rem; }
  .faq__search svg{ position:absolute; left:14px; top:50%; transform:translateY(-50%); color:var(--muted); pointer-events:none; }
  .faq__search .input{ padding-left:2.6rem; }
  .faq__empty{ background:var(--surface); border:1px solid var(--line); border-radius:var(--radius-sm); padding:.9rem 1.1rem; color:var(--muted); }
</style>

<script>
  const search = document.querySelector('[data-faq-search]') as HTMLInputElement | null;
  const items = Array.from(document.querySelectorAll<HTMLDetailsElement>('.faq__item'));
  const empty = document.querySelector('[data-faq-empty]') as HTMLElement | null;
  search?.addEventListener('input', () => {
    const q = search.value.trim().toLowerCase();
    let shown = 0;
    for (const it of items) {
      const match = !q || (it.textContent ?? '').toLowerCase().includes(q);
      it.hidden = !match;
      if (match) { shown++; if (q) it.open = true; }
    }
    if (empty) empty.hidden = shown !== 0;
  });
</script>
