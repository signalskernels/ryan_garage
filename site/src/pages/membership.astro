---
import Base from '@/layouts/Base.astro';
import PageHeader from '@/components/PageHeader.astro';
import CtaBand from '@/components/CtaBand.astro';
import { site } from '@/data/site';
import { page } from '@/lib/pages';

const c = page('membership');
---
<Base title={c.meta.title} description={c.meta.description}>
  <PageHeader
    title={c.header.title}
    subtitle={c.header.subtitle}
    crumbs={[{ label: c.header.crumb }]}
  />

  <section class="section">
    <div class="wrap mem">
      <div class="prose mem__copy">
        <h2>{c.intro.heading}</h2>
        <p>{c.intro.lead}</p>
        <h3>{c.intro.includesHeading}</h3>
        <ul class="check2">
          {c.includes.map((i: string) => <li>{i}</li>)}
        </ul>
        <p class="muted" style="font-size:.86rem;">{c.intro.note}</p>
      </div>

      <aside class="mem__card card">
        <div class="mem__tag">{c.card.tag}</div>
        <h3>{c.card.title}</h3>
        <p class="mem__price">{c.card.price}<span>{c.card.priceNote}</span></p>
        <ul class="mem__perks">
          {c.card.perks.map((p: string) => <li>{p}</li>)}
        </ul>
        <a href={site.phoneHref} class="btn btn--block btn--lg">{c.card.callLabel}</a>
        <a href="/book" class="btn btn--block btn--navy">{c.card.bookLabel}</a>
      </aside>
    </div>
  </section>

  <CtaBand title={c.cta.title} />
</Base>

<style>
  .mem{ display:grid; grid-template-columns:1.3fr .7fr; gap:clamp(28px,4vw,52px); align-items:start; }
  @media (max-width:860px){ .mem{ grid-template-columns:1fr; } }
  .check2{ list-style:none; padding:0; columns:2 200px; column-gap:1.4rem; }
  .check2 li{ position:relative; padding-left:1.6rem; margin:.45rem 0; break-inside:avoid; }
  .check2 li::before{ content:'✓'; position:absolute; left:0; color:#fff; background:var(--gold); width:1.15rem; height:1.15rem;
    border-radius:50%; font-size:.68rem; font-weight:800; display:flex; align-items:center; justify-content:center; top:.2rem; }
  .mem__card{ padding:1.6rem; position:sticky; top:96px; border-color:var(--gold-600); }
  .mem__tag{ display:inline-block; font-size:.7rem; font-weight:800; text-transform:uppercase; letter-spacing:.06em;
    color:var(--navy-900); background:var(--gold); padding:.25em .7em; border-radius:999px; margin-bottom:.6rem; }
  .mem__price{ font-size:1.8rem; font-weight:800; color:var(--navy); margin:.2rem 0 1rem; }
  .mem__price span{ display:block; font-size:.8rem; font-weight:600; color:var(--muted); }
  .mem__perks{ list-style:none; padding:0; margin:0 0 1.2rem; font-weight:600; color:var(--navy); }
  .mem__perks li{ margin:.4rem 0; }
  @media (max-width:860px){ .mem__card{ position:static; } }
</style>
