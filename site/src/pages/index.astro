---
import { Image } from 'astro:assets';
import Base from '@/layouts/Base.astro';
import { site } from '@/data/site';
import { services } from '@/data/services';
import { locations } from '@/data/locations';
import { featuredReviews } from '@/data/reviews';
import { coupons } from '@/data/coupons';
import { photo } from '@/lib/photos';
import ServiceIcon from '@/components/ServiceIcon.astro';
import ReviewCard from '@/components/ReviewCard.astro';
import TrustStrip from '@/components/TrustStrip.astro';
import LeadForm from '@/components/LeadForm.astro';
import EstimateForm from '@/components/EstimateForm.astro';
import CtaBand from '@/components/CtaBand.astro';
import { page } from '@/lib/pages';

const c = page('home');
---
<Base
  title={undefined}
  description={c.meta.description}
>
  <!-- HERO -->
  <section class="hero">
    <Image src={photo(c.hero.image.src)} alt={c.hero.image.alt} widths={[760, 1100, 1600]} sizes="100vw" class="hero__bg" loading="eager" fetchpriority="high" />
    <div class="hero__scrim"></div>
    <div class="wrap hero__in">
      <div class="hero__copy">
        <p class="eyebrow">{c.hero.eyebrow}</p>
        <h1>{site.hero.pre} <span class="text-gold">{site.hero.highlight}</span> {site.hero.post}</h1>
        <p class="lead">{site.hero.sub}</p>
        <div class="hero__rating">
          <span class="stars">★★★★★</span>
          <span set:html={c.hero.ratingHtml} />
        </div>
        <div class="cta-row">
          <a href={site.phoneHref} class="btn btn--lg">{c.hero.callLabel}</a>
          <a href="/book" class="btn btn--lg btn--ghost">{c.hero.requestLabel}</a>
        </div>
        <ul class="hero__badges">
          {c.hero.badges.map((b: string) => <li>{b}</li>)}
        </ul>
      </div>
      <div class="hero__form">
        <EstimateForm />
      </div>
    </div>
  </section>

  <TrustStrip />

  <!-- SERVICES -->
  <section class="section" id="services">
    <div class="wrap">
      <div class="sec-head">
        <p class="eyebrow">{c.services.eyebrow}</p>
        <h2>{c.services.heading}</h2>
        <p class="lead">{c.services.lead}</p>
      </div>
      <div class="grid cols-4 svc-grid">
        {services.map((s) => (
          <a href={`/services/${s.slug}`} class="svc card card--hover">
            <div class="svc__icon"><ServiceIcon name={s.icon} /></div>
            <h3>{s.title}</h3>
            <p>{s.short}</p>
            <span class="svc__link">Learn more →</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- HIDDEN ADVANTAGE: REVIEWS -->
  <section class="section section--surface" id="reviews">
    <div class="wrap">
      <div class="sec-head center">
        <p class="eyebrow">{c.reviews.eyebrow}</p>
        <h2>{c.reviews.heading}</h2>
        <p class="lead">{c.reviews.lead}</p>
      </div>
      <div class="grid cols-3 rv-grid">
        {featuredReviews.slice(0, 6).map((r) => <ReviewCard review={r} />)}
      </div>
      <div class="cta-row cta-row--center">
        <a href="/reviews" class="btn btn--outline">{c.reviews.moreLabel}</a>
        <a href={site.reviews.reviewLink} class="btn" target="_blank" rel="noopener">{c.reviews.googleLabel}</a>
      </div>
    </div>
  </section>

  <!-- WHY US -->
  <section class="section">
    <div class="wrap">
      <div class="sec-head">
        <p class="eyebrow">{c.why.eyebrow}</p>
        <h2>{c.why.heading}</h2>
      </div>
      <div class="grid cols-4">
        {c.why.items.map((w: { icon: string; t: string; d: string }) => (
          <div class="why">
            <div class="why__icon"><ServiceIcon name={w.icon} size={26} /></div>
            <h3>{w.t}</h3>
            <p>{w.d}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- PROCESS -->
  <section class="section section--navy">
    <div class="wrap">
      <div class="sec-head">
        <p class="eyebrow">{c.process.eyebrow}</p>
        <h2>{c.process.heading}</h2>
      </div>
      <div class="grid cols-4 steps">
        {c.process.steps.map((s: { n: string; t: string; d: string }) => (
          <div class="step">
            <div class="step__n">{s.n}</div>
            <h3>{s.t}</h3>
            <p>{s.d}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- COUPONS -->
  <section class="section section--surface">
    <div class="wrap">
      <div class="sec-head center">
        <p class="eyebrow">{c.coupons.eyebrow}</p>
        <h2>{c.coupons.heading}</h2>
      </div>
      <div class="grid cols-4">
        {coupons.map((cp) => (
          <div class="coupon">
            <div class="coupon__amt">{cp.amount}</div>
            <h3>{cp.title}</h3>
            <p>{cp.detail}</p>
          </div>
        ))}
      </div>
      <p class="center" style="margin-top:1.4rem;"><a href="/coupons" class="btn btn--outline">{c.coupons.detailsLabel}</a></p>
    </div>
  </section>

  <!-- SERVICE AREA -->
  <section class="section">
    <div class="wrap area">
      <div>
        <p class="eyebrow">{c.area.eyebrow}</p>
        <h2>{c.area.heading}</h2>
        <p class="lead">{c.area.lead.replace('{count}', String(locations.length))}</p>
        <a href="/service-area" class="btn btn--navy" style="margin-top:.6rem;">{c.area.viewAllLabel.replace('{count}', String(locations.length))}</a>
      </div>
      <ul class="area__chips">
        {locations.slice(0, 17).map((l) => <li><a href={`/service-area/${l.slug}`}>{l.name}, IL</a></li>)}
        <li><a href="/service-area" class="area__more">{c.area.moreLabel.replace('{count}', String(locations.length - 17))}</a></li>
      </ul>
    </div>
  </section>

  <!-- LEAD FORM -->
  <section class="section section--surface" id="contact">
    <div class="wrap form-split">
      <div class="form-split__copy">
        <p class="eyebrow">{c.leadSection.eyebrow}</p>
        <h2>{c.leadSection.heading}</h2>
        <p class="lead">{c.leadSection.lead}</p>
        <a href={site.phoneHref} class="hero__rating hero__rating--call">
          <span class="stars">📞</span><span><b>{site.phone}</b><br><small>{c.leadSection.hoursNote}</small></span>
        </a>
        <ul class="form-split__list">
          {c.leadSection.points.map((p: string) => <li>{p}</li>)}
        </ul>
      </div>
      <LeadForm heading={c.leadSection.formHeading} />
    </div>
  </section>

  <CtaBand />
</Base>

<style>
  .sec-head{ max-width:60ch; margin-bottom:clamp(24px,3vw,40px); }
  .sec-head.center{ margin-inline:auto; }
  .sec-head .lead{ margin-bottom:0; }
  .sec-head.center .lead{ margin-inline:auto; }

  /* hero — full-bleed photo + scrim, white copy left, estimate form right */
  .hero{ position:relative; isolation:isolate; overflow:hidden; background:var(--navy-900); padding-block:clamp(38px,5.5vw,76px); }
  .hero__bg{ position:absolute; inset:0; width:100%; height:100%; object-fit:cover; z-index:-2; }
  .hero__scrim{ position:absolute; inset:0; z-index:-1;
    background:linear-gradient(100deg, rgba(8,22,46,.94) 0%, rgba(8,22,46,.86) 40%, rgba(8,22,46,.55) 72%, rgba(8,22,46,.4) 100%); }
  .hero__in{ display:grid; grid-template-columns:1.05fr .95fr; gap:clamp(24px,4vw,56px); align-items:center; }
  .hero__copy{ color:#e7eefa; }
  .hero__copy h1{ color:#fff; margin:.2rem 0 .8rem; }
  .hero__copy .lead{ color:#b9c8de; }
  .hero__rating{ display:flex; align-items:center; gap:.6rem; margin:1.1rem 0 .2rem; font-size:.98rem; color:#dbe6f5; }
  .hero__rating .stars{ font-size:1.15rem; }
  .hero__rating b{ color:#fff; }
  .hero__badges{ list-style:none; display:flex; flex-wrap:wrap; gap:.5rem 1.3rem; padding:0; margin:1.5rem 0 0; font-size:.88rem; font-weight:600; color:#dbe6f5; }
  .hero__form{ width:100%; max-width:430px; justify-self:end; }
  @media (max-width:900px){
    .hero__in{ grid-template-columns:1fr; }
    .hero__form{ justify-self:stretch; max-width:none; }
  }

  /* call-to-action variant of the rating, used on the light lead-form section */
  .hero__rating--call{ display:inline-flex; margin-top:1.2rem; color:var(--body); }
  .hero__rating--call small{ color:var(--muted); }
  .hero__rating--call b{ font-size:1.25rem; color:var(--navy); }

  /* services */
  .svc{ display:flex; flex-direction:column; padding:1.4rem; }
  .svc__icon{ width:52px; height:52px; border-radius:12px; background:var(--gold-soft); color:var(--gold-600);
    display:flex; align-items:center; justify-content:center; margin-bottom:.9rem; }
  .svc h3{ font-size:1.12rem; margin-bottom:.35rem; }
  .svc p{ font-size:.92rem; color:var(--muted); flex:1; margin-bottom:.8rem; }
  .svc__link{ font-weight:700; font-size:.9rem; color:var(--navy); }

  /* reviews */
  .rv-grid{ margin-bottom:1.8rem; }

  /* why */
  .why__icon{ width:48px; height:48px; border-radius:50%; background:var(--navy); color:#fff;
    display:flex; align-items:center; justify-content:center; margin-bottom:.8rem; }
  .why h3{ font-size:1.1rem; margin-bottom:.3rem; }
  .why p{ font-size:.93rem; color:var(--muted); }

  /* steps */
  .step__n{ width:42px; height:42px; border-radius:50%; background:var(--gold); color:var(--navy-900);
    font-weight:800; display:flex; align-items:center; justify-content:center; margin-bottom:.7rem; }
  .step h3{ font-size:1.08rem; margin-bottom:.3rem; }
  .step p{ font-size:.92rem; color:#aec3e0; }

  /* coupons */
  .coupon{ background:#fff; border:1px dashed var(--gold-600); border-radius:var(--radius); padding:1.3rem; text-align:center; }
  .coupon__amt{ font-size:1.7rem; font-weight:800; color:var(--gold-600); letter-spacing:-.02em; }
  .coupon h3{ font-size:1.02rem; margin:.2rem 0 .4rem; }
  .coupon p{ font-size:.86rem; color:var(--muted); margin:0; }

  /* area */
  .area{ display:grid; grid-template-columns:1fr 1.1fr; gap:clamp(24px,4vw,48px); align-items:center; }
  .area__chips{ list-style:none; display:flex; flex-wrap:wrap; gap:.5rem; padding:0; margin:0; }
  .area__chips a{ display:inline-block; padding:.45em .9em; border:1px solid var(--line); border-radius:999px;
    font-size:.88rem; font-weight:600; color:var(--body); background:#fff; }
  .area__chips a:hover{ border-color:var(--navy); color:var(--navy); background:var(--surface); }
  .area__chips .area__more{ background:var(--navy); color:#fff; border-color:var(--navy); }
  .area__chips .area__more:hover{ background:var(--navy-700); color:#fff; }
  @media (max-width:820px){ .area{ grid-template-columns:1fr; } }

  /* form split */
  .form-split{ display:grid; grid-template-columns:1fr 1.05fr; gap:clamp(24px,4vw,48px); align-items:start; }
  .form-split__list{ list-style:none; padding:0; margin:1.4rem 0 0; }
  .form-split__list li{ margin:.5rem 0; font-weight:600; color:var(--navy); }
  @media (max-width:860px){ .form-split{ grid-template-columns:1fr; } }
</style>
