---
import Base from '@/layouts/Base.astro';
import PageHeader from '@/components/PageHeader.astro';
import CtaBand from '@/components/CtaBand.astro';
import { site } from '@/data/site';
import { page } from '@/lib/pages';

const c = page('financing');
---
<Base title={c.meta.title} description={c.meta.description}>
  <PageHeader
    title={c.header.title}
    subtitle={c.header.subtitle}
    crumbs={[{ label: c.header.crumb }]}
  />

  <section class="section">
    <div class="wrap fin">
      <div class="prose">
        <h2>{c.intro.heading}</h2>
        <p>{c.intro.paragraph}</p>
        <div class="grid cols-3" style="margin:1.6rem 0;">
          {c.points.map((p: { t: string; d: string }) => (
            <div class="fin__pt card">
              <h3>{p.t}</h3>
              <p>{p.d}</p>
            </div>
          ))}
        </div>
        <p class="muted" style="font-size:.86rem;">{c.intro.disclaimer}</p>
      </div>

      <aside class="fin__box card">
        <h3>{c.box.heading}</h3>
        <p>{c.box.text}</p>
        <a href={site.phoneHref} class="btn btn--block btn--lg">{c.box.callLabel}</a>
        <a href="/book" class="btn btn--block btn--navy">{c.box.quoteLabel}</a>
      </aside>
    </div>
  </section>

  <CtaBand title={c.cta.title} text={c.cta.text} />
</Base>

<style>
  .fin{ display:grid; grid-template-columns:1.3fr .7fr; gap:clamp(28px,4vw,52px); align-items:start; }
  @media (max-width:860px){ .fin{ grid-template-columns:1fr; } }
  .fin__pt{ padding:1.2rem; }
  .fin__pt h3{ font-size:1.02rem; margin-bottom:.3rem; }
  .fin__pt p{ font-size:.9rem; color:var(--muted); margin:0; }
  .fin__box{ padding:1.5rem; position:sticky; top:96px; }
  .fin__box h3{ margin-bottom:.5rem; }
  .fin__box > p{ color:var(--muted); font-size:.92rem; margin-bottom:1rem; }
  .fin__box .btn{ margin-bottom:.5rem; }
  @media (max-width:860px){ .fin__box{ position:static; } }
</style>
