---
import { Image } from 'astro:assets';
import Base from '@/layouts/Base.astro';
import PageHeader from '@/components/PageHeader.astro';
import CtaBand from '@/components/CtaBand.astro';
import { photo } from '@/lib/photos';
import { page } from '@/lib/pages';

const c = page('gallery');
---
<Base title={c.meta.title} description={c.meta.description}>
  <PageHeader
    title={c.header.title}
    subtitle={c.header.subtitle}
    crumbs={[{ label: c.header.crumb }]}
  />

  <section class="section">
    <div class="wrap">
      <div class="gal">
        {c.images.map((g: { src: string; caption: string }, i: number) => (
          <figure class="gal__item">
            <Image src={photo(g.src)} alt={`${g.caption} — Ryan Garage Door`} widths={[300, 480]} sizes="(max-width:600px) 50vw, 300px" loading={i < 4 ? 'eager' : 'lazy'} />
            <figcaption>{g.caption}</figcaption>
          </figure>
        ))}
      </div>
      <p class="gal__note" set:html={c.note.noteHtml}></p>
    </div>
  </section>

  <CtaBand />
</Base>

<style>
  .gal{ columns:4 220px; column-gap:14px; }
  .gal__item{ break-inside:avoid; margin:0 0 14px; position:relative; border-radius:var(--radius-sm); overflow:hidden; box-shadow:var(--shadow-sm); }
  .gal__item :global(img){ width:100%; height:auto; display:block; transition:transform .35s ease; }
  .gal__item:hover :global(img){ transform:scale(1.06); }
  .gal__item figcaption{ position:absolute; left:0; right:0; bottom:0; padding:.9rem .8rem .6rem; color:#fff; font-size:.82rem; font-weight:600;
    background:linear-gradient(transparent, rgba(10,31,61,.82)); }
  .gal__note{ text-align:center; color:var(--muted); margin-top:1.6rem; }
</style>
