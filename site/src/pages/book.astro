---
import Base from '@/layouts/Base.astro';
import PageHeader from '@/components/PageHeader.astro';
import LeadForm from '@/components/LeadForm.astro';
import { site } from '@/data/site';

const steps = [
  { t: 'You send your request', d: 'Pick a service and a preferred time. Takes about a minute.' },
  { t: 'We confirm fast', d: 'We’ll call or text to lock in a time — often the same day.' },
  { t: 'We show up & fix it', d: 'Honest diagnosis, upfront quote, and a safety-tested door before we leave.' },
];
---
<Base title="Request Service" description={`Request garage door service from Ryan Garage Door. Pick a time and we’ll confirm fast — often same-day. Or call ${site.phone} 24/7.`}>
  <PageHeader
    title="Request Service"
    subtitle="Tell us what you need and when. We’ll confirm your appointment fast — usually the same day. For emergencies, calling is quickest."
    crumbs={[{ label: 'Request Service' }]}
  />

  <section class="section">
    <div class="wrap book">
      <div class="book__side">
        <div class="card book__call">
          <p class="eyebrow" style="color:var(--gold-600);">Fastest option</p>
          <h3>Call us — we pick up 24/7</h3>
          <a href={site.phoneHref} class="btn btn--lg btn--block">Call {site.phone}</a>
          <p class="muted" style="font-size:.86rem; margin:.8rem 0 0;">Broken spring, stuck door, or after-hours emergency? A quick call gets help on the way fastest.</p>
        </div>

        <h3 class="book__h">What happens next</h3>
        <ol class="book__steps">
          {steps.map((s, i) => (
            <li>
              <span class="book__num">{i + 1}</span>
              <span><b>{s.t}</b><small>{s.d}</small></span>
            </li>
          ))}
        </ol>

        <div class="book__trust">
          <span class="stars">★★★★★</span>
          <p>{site.reviews.total}+ five-star reviews · Fully insured · BBB-accredited</p>
        </div>
      </div>

      <div class="book__form">
        {/* Base build = appointment request (free). When the client opts into
            Housecall Pro / Jobber, the real-time booking embed drops in here. */}
        <LeadForm heading="Request your appointment" cta="Request appointment" />
      </div>
    </div>
  </section>
</Base>

<style>
  .book{ display:grid; grid-template-columns:.85fr 1.15fr; gap:clamp(28px,4vw,52px); align-items:start; }
  @media (max-width:860px){ .book{ grid-template-columns:1fr; } .book__form{ order:-1; } }
  .book__call{ padding:1.4rem; margin-bottom:1.6rem; }
  .book__call h3{ margin-bottom:.7rem; }
  .book__h{ margin-bottom:.9rem; }
  .book__steps{ list-style:none; padding:0; margin:0 0 1.6rem; }
  .book__steps li{ display:flex; gap:.9rem; align-items:flex-start; margin-bottom:1rem; }
  .book__num{ flex:none; width:30px; height:30px; border-radius:50%; background:var(--navy); color:#fff; font-weight:800;
    display:flex; align-items:center; justify-content:center; font-size:.9rem; }
  .book__steps b{ display:block; color:var(--ink); }
  .book__steps small{ color:var(--muted); }
  .book__trust{ background:var(--surface); border-radius:var(--radius); padding:1rem 1.2rem; }
  .book__trust .stars{ font-size:1.1rem; }
  .book__trust p{ margin:.2rem 0 0; font-size:.86rem; color:var(--body); font-weight:600; }
</style>
