---
import Base from '@/layouts/Base.astro';
import PageHeader from '@/components/PageHeader.astro';
import CtaBand from '@/components/CtaBand.astro';
import ReviewCard from '@/components/ReviewCard.astro';
import { reviews } from '@/data/reviews';
import { site } from '@/data/site';

const platforms = [
  { name: 'Google', count: site.reviews.google, note: 'All 5 stars' },
  { name: 'Thumbtack', count: site.reviews.thumbtack, note: '160+ hires' },
  { name: 'Angi / HomeAdvisor', count: site.reviews.homeadvisor, note: 'All 5 stars' },
  { name: 'Nextdoor', count: site.reviews.nextdoor, note: 'Neighbor picks' },
];
---
<Base title="Reviews" description={`Read ${site.reviews.total}+ verified five-star reviews for Ryan Garage Door from Google, Thumbtack, Angi and Nextdoor. Then leave your own.`}>
  <PageHeader
    title="Reviews & Reputation"
    subtitle={`${site.reviews.total}+ verified reviews across Google, Thumbtack, Angi and Nextdoor — and every single one is five stars.`}
    crumbs={[{ label: 'Reviews' }]}
  />

  <section class="section--tight" style="padding-top:clamp(28px,4vw,44px);">
    <div class="wrap">
      <div class="rv-stats">
        {platforms.map((p) => (
          <div class="rv-stat card">
            <span class="stars">★★★★★</span>
            <div class="rv-stat__n">{p.count}</div>
            <div class="rv-stat__src">{p.name}</div>
            <div class="rv-stat__note">{p.note}</div>
          </div>
        ))}
      </div>
      <p class="rv-intro">We’re grateful that homeowners across the NW Chicago suburbs trust us — and take the time to say so. Below is a hand-picked selection of verbatim reviews. Want to see them all? <a href={site.reviews.googleProfileUrl} target="_blank" rel="noopener">View our Google profile</a>.</p>
    </div>
  </section>

  <section class="section" style="padding-top:0;">
    <div class="wrap grid cols-3 rv-grid">
      {reviews.map((r) => <ReviewCard review={r} />)}
    </div>
  </section>

  <section class="section section--surface center">
    <div class="wrap measure" style="margin-inline:auto;">
      <h2>Worked with us? We’d love your review.</h2>
      <p class="lead" style="margin:.6rem auto 1.4rem;">It takes 30 seconds and helps your neighbors find honest garage door help.</p>
      <a href={site.reviews.googleProfileUrl} class="btn btn--lg" target="_blank" rel="noopener">Leave us a Google review</a>
    </div>
  </section>

  <CtaBand />
</Base>

<style>
  .rv-stats{ display:grid; grid-template-columns:repeat(4,1fr); gap:1rem; }
  @media (max-width:760px){ .rv-stats{ grid-template-columns:repeat(2,1fr); } }
  .rv-stat{ text-align:center; padding:1.3rem 1rem; }
  .rv-stat .stars{ font-size:1rem; }
  .rv-stat__n{ font-size:2rem; font-weight:800; color:var(--navy); line-height:1; margin-top:.2rem; }
  .rv-stat__src{ font-weight:700; color:var(--ink); margin-top:.2rem; }
  .rv-stat__note{ font-size:.8rem; color:var(--muted); }
  .rv-intro{ text-align:center; color:var(--muted); max-width:64ch; margin:1.6rem auto 0; }
  .rv-grid{ align-items:start; }
</style>
