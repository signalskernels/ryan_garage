---
import Base from '@/layouts/Base.astro';
import PageHeader from '@/components/PageHeader.astro';
import CtaBand from '@/components/CtaBand.astro';
import ReviewCard from '@/components/ReviewCard.astro';
import { reviews } from '@/data/reviews';
import { site } from '@/data/site';
import { page } from '@/lib/pages';

const c = page('reviews');
---
<Base title={c.meta.title} description={c.meta.description}>
  <PageHeader
    title={c.header.title}
    subtitle={c.header.subtitle}
    crumbs={[{ label: c.header.crumb }]}
  />

  <section class="section--tight" style="padding-top:clamp(28px,4vw,44px);">
    <div class="wrap">
      <div class="rv-stats">
        {c.platforms.map((p: { name: string; count: string; note: string }) => (
          <div class="rv-stat card">
            <span class="stars">★★★★★</span>
            <div class="rv-stat__n">{p.count}</div>
            <div class="rv-stat__src">{p.name}</div>
            <div class="rv-stat__note">{p.note}</div>
          </div>
        ))}
      </div>
      <p class="rv-intro">{c.intro.pre}<a href={site.reviews.googleProfileUrl} target="_blank" rel="noopener">{c.intro.linkLabel}</a>{c.intro.post}</p>
    </div>
  </section>

  <section class="section" style="padding-top:0;">
    <div class="wrap grid cols-3 rv-grid">
      {reviews.map((r) => <ReviewCard review={r} />)}
    </div>
  </section>

  <section class="section section--surface center">
    <div class="wrap measure" style="margin-inline:auto;">
      <h2>{c.leaveReview.heading}</h2>
      <p class="lead" style="margin:.6rem auto 1.4rem;">{c.leaveReview.text}</p>
      <a href={site.reviews.googleProfileUrl} class="btn btn--lg" target="_blank" rel="noopener">{c.leaveReview.buttonLabel}</a>
    </div>
  </section>

  <CtaBand />
</Base>

<style>
  .rv-stats{ display:grid; grid-template-columns:repeat(4,1fr); gap:1rem; }
  @media (max-width:760px){ .rv-stats{ grid-template-columns:repeat(2,1fr); } }
  .rv-stat{ text-align:center; padding:1.3rem 1rem; }
  .rv-stat .stars{ font-size:1rem; }
  .rv-stat__n{ font-size:2rem; font-weight:800; color:var(--navy); line-height:1; margin-top:.2rem; }
  .rv-stat__src{ font-weight:700; color:var(--ink); margin-top:.2rem; }
  .rv-stat__note{ font-size:.8rem; color:var(--muted); }
  .rv-intro{ text-align:center; color:var(--muted); max-width:64ch; margin:1.6rem auto 0; }
  .rv-grid{ align-items:start; }
</style>
