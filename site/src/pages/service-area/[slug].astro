---
import Base from '@/layouts/Base.astro';
import PageHeader from '@/components/PageHeader.astro';
import CtaBand from '@/components/CtaBand.astro';
import LeadForm from '@/components/LeadForm.astro';
import ReviewCard from '@/components/ReviewCard.astro';
import ServiceIcon from '@/components/ServiceIcon.astro';
import { locations, locationBySlug } from '@/data/locations';
import { services } from '@/data/services';
import { reviews } from '@/data/reviews';
import { site } from '@/data/site';

export function getStaticPaths() {
  return locations.map((l, i) => ({ params: { slug: l.slug }, props: { loc: l, idx: i } }));
}
const { loc, idx } = Astro.props;
const review = reviews[idx % reviews.length];
const nearby = loc.nearby.map((s) => locationBySlug(s)).filter(Boolean);

const jsonLd = [{
  '@context': 'https://schema.org',
  '@type': 'Service',
  serviceType: 'Garage Door Repair & Installation',
  provider: { '@type': 'HomeAndConstructionBusiness', name: site.name, telephone: '+1-224-770-0587' },
  areaServed: { '@type': 'City', name: `${loc.name}, IL`, containedInPlace: loc.county },
  url: new URL(`/service-area/${loc.slug}`, Astro.site).href,
}];
---
<Base
  title={`Garage Door Repair in ${loc.name}, IL`}
  description={`Fast, fully-insured mobile garage door repair, installation and service in ${loc.name}, IL (${loc.county}). 24/7 emergency service. ${site.reviews.total}+ five-star reviews. Call ${site.phone}.`}
  jsonLd={jsonLd}
>
  <PageHeader
    title={`Garage Door Repair in ${loc.name}, IL`}
    subtitle={loc.blurb}
    crumbs={[{ label: 'Service Area', href: '/service-area' }, { label: `${loc.name}, IL` }]}
  />

  <section class="section">
    <div class="wrap loc">
      <article class="prose loc__main">
        <p>Looking for a dependable garage door company in <strong>{loc.name}, {loc.county}</strong>? Ryan Garage Door brings honest, professional, fully-insured mobile service right to your driveway. Whether you’ve got a snapped spring, a dead opener, or you’re ready for a beautiful new door, our local team responds fast — often the same day.</p>
        <p>We know {loc.name} well — from {loc.spots.slice(0, 2).join(' and ')} to the neighborhoods around {loc.spots[loc.spots.length - 1]} — and we’re proud to keep its garage doors running safely and quietly through every Illinois season, including the brutal cold snaps when springs and openers tend to give out.</p>

        <h2>Garage door services we offer in {loc.name}</h2>
        <div class="loc__svcs">
          {services.map((s) => (
            <a href={`/services/${s.slug}`} class="loc__svc">
              <span class="loc__svc-ic"><ServiceIcon name={s.icon} size={20} /></span>
              <span><b>{s.title}</b><small>{s.short}</small></span>
            </a>
          ))}
        </div>

        <h2>Why {loc.name} homeowners choose us</h2>
        <ul class="check">
          <li><strong>Same-day &amp; 24/7 emergency service</strong> — a stuck or broken door can’t wait, and neither do we.</li>
          <li><strong>Honest, upfront pricing</strong> — we diagnose the real problem and quote it before we start.</li>
          <li><strong>Fully insured &amp; BBB-accredited</strong> — experienced technicians you can trust in your home.</li>
          <li><strong>Top-rated locally</strong> — {site.reviews.total}+ five-star reviews from {loc.county} and across the NW suburbs.</li>
        </ul>

        <p>We’re a short drive from {loc.name}, so we also serve nearby {nearby.map((n) => n!.name).join(', ')} and many other communities within about {site.serviceRadiusMiles} miles of Huntley. Wherever you are in the area, you get the same fast, friendly, professional service.</p>
      </article>

      <aside class="loc__side">
        <ReviewCard review={review} />
        <div class="side-card card">
          <h3>Garage door help in {loc.name}</h3>
          <a href={site.phoneHref} class="btn btn--block btn--lg">Call {site.phone}</a>
          <a href="/book" class="btn btn--block btn--navy">Request Service</a>
        </div>
        {nearby.length > 0 && (
          <div class="side-card card">
            <h4>Nearby areas we serve</h4>
            <ul class="loc__near">
              {nearby.map((n) => <li><a href={`/service-area/${n!.slug}`}>{n!.name}, IL →</a></li>)}
            </ul>
          </div>
        )}
      </aside>
    </div>
  </section>

  <section class="section section--surface">
    <div class="wrap"><LeadForm heading={`Request service in ${loc.name}`} intro="Send a few details and we’ll confirm a time fast — usually the same day." /></div>
  </section>

  <CtaBand />
</Base>

<style>
  .loc{ display:grid; grid-template-columns:1fr 320px; gap:clamp(28px,4vw,52px); align-items:start; }
  @media (max-width:920px){ .loc{ grid-template-columns:1fr; } }
  .loc__svcs{ display:grid; grid-template-columns:1fr 1fr; gap:.7rem; margin:1rem 0 1.6rem; }
  @media (max-width:520px){ .loc__svcs{ grid-template-columns:1fr; } }
  .loc__svc{ display:flex; align-items:center; gap:.7rem; padding:.7rem .9rem; border:1px solid var(--line); border-radius:var(--radius-sm); background:#fff; }
  .loc__svc:hover{ border-color:var(--navy); }
  .loc__svc-ic{ width:38px; height:38px; flex:none; border-radius:9px; background:var(--gold-soft); color:var(--gold-600); display:flex; align-items:center; justify-content:center; }
  .loc__svc b{ display:block; color:var(--ink); font-size:.95rem; }
  .loc__svc small{ display:block; color:var(--muted); font-size:.78rem; line-height:1.3; }
  .check{ list-style:none; padding:0; }
  .check li{ position:relative; padding-left:1.8rem; margin:.55rem 0; }
  .check li::before{ content:'✓'; position:absolute; left:0; top:.15rem; color:#fff; background:var(--gold); width:1.25rem; height:1.25rem;
    border-radius:50%; font-size:.72rem; font-weight:800; display:flex; align-items:center; justify-content:center; }
  .loc__side{ position:sticky; top:96px; display:grid; gap:1rem; }
  @media (max-width:920px){ .loc__side{ position:static; } }
  .side-card{ padding:1.3rem; }
  .side-card h3{ margin-bottom:.7rem; }
  .side-card .btn{ margin-bottom:.5rem; }
  .loc__near{ list-style:none; padding:0; margin:0; }
  .loc__near li{ margin:.4rem 0; }
</style>
