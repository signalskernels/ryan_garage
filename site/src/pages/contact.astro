---
import Base from '@/layouts/Base.astro';
import PageHeader from '@/components/PageHeader.astro';
import LeadForm from '@/components/LeadForm.astro';
import { site, days } from '@/data/site';
---
<Base title="Contact Us" description={`Contact Ryan Garage Door — call ${site.phone} 24/7, or send a request online. Mobile garage door service across Huntley, IL and the NW suburbs.`}>
  <PageHeader
    title="Contact Us"
    subtitle="Call us 24/7, or send a request and we’ll get right back to you. We’re here to help with anything garage door related."
    crumbs={[{ label: 'Contact' }]}
  />

  <section class="section">
    <div class="wrap contact">
      <div class="contact__info">
        <div class="contact__block">
          <h3>Call or text</h3>
          <a href={site.phoneHref} class="contact__phone">{site.phone}</a>
          <p class="muted">Available 24 hours · 7 days a week</p>
        </div>
        <div class="contact__block">
          <h3>Service area</h3>
          <p>Mobile service based in {site.address.locality}, {site.address.region} {site.address.postalCode} — covering homes within about {site.serviceRadiusMiles} miles across the NW Chicago suburbs.</p>
          <a href="/service-area">See all areas we serve →</a>
        </div>
        <div class="contact__block">
          <h3>Hours</h3>
          <ul class="contact__hours">
            {days.map((d) => <li><span>{d}</span><b>Open 24 hours</b></li>)}
          </ul>
        </div>
        <div class="contact__block">
          <h3>Payment accepted</h3>
          <p class="muted">{site.paymentAccepted.join(' · ')}</p>
        </div>
        <a class="btn btn--lg btn--block" href={site.phoneHref}>Call {site.phone}</a>
      </div>

      <div class="contact__form">
        <LeadForm formName="contact" heading="Send us a message" intro="Fill this out and we’ll reach out shortly. For emergencies, calling is fastest." scheduling={false} cta="Send message" />
      </div>
    </div>
  </section>
</Base>

<style>
  .contact{ display:grid; grid-template-columns:.85fr 1.15fr; gap:clamp(28px,4vw,52px); align-items:start; }
  @media (max-width:860px){ .contact{ grid-template-columns:1fr; } }
  .contact__block{ padding-bottom:1.2rem; margin-bottom:1.2rem; border-bottom:1px solid var(--line); }
  .contact__block h3{ font-size:1.05rem; margin-bottom:.4rem; }
  .contact__phone{ font-size:1.8rem; font-weight:800; color:var(--navy); letter-spacing:-.02em; display:block; }
  .contact__hours{ list-style:none; padding:0; margin:0; font-size:.92rem; }
  .contact__hours li{ display:flex; justify-content:space-between; padding:.3rem 0; border-bottom:1px solid var(--line-2); }
  .contact__hours b{ color:var(--navy); }
</style>
