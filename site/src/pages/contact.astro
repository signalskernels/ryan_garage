---
import Base from '@/layouts/Base.astro';
import PageHeader from '@/components/PageHeader.astro';
import LeadForm from '@/components/LeadForm.astro';
import { site, days } from '@/data/site';
import { page } from '@/lib/pages';

const c = page('contact');
---
<Base title={c.meta.title} description={c.meta.description}>
  <PageHeader
    title={c.header.title}
    subtitle={c.header.subtitle}
    crumbs={[{ label: c.header.crumb }]}
  />

  <section class="section">
    <div class="wrap contact">
      <div class="contact__info">
        <div class="contact__block">
          <h3>{c.callBlock.heading}</h3>
          <a href={site.phoneHref} class="contact__phone">{site.phone}</a>
          <p class="muted">{c.callBlock.availability}</p>
        </div>
        <div class="contact__block">
          <h3>{c.areaBlock.heading}</h3>
          <p>{c.areaBlock.text}</p>
          <a href="/service-area">{c.areaBlock.link}</a>
        </div>
        <div class="contact__block">
          <h3>{c.hours.heading}</h3>
          <ul class="contact__hours">
            {days.map((d) => <li><span>{d}</span><b>{c.hours.openLabel}</b></li>)}
          </ul>
        </div>
        <div class="contact__block">
          <h3>{c.payBlock.heading}</h3>
          <p class="muted">{site.paymentAccepted.join(' · ')}</p>
        </div>
        <a class="btn btn--lg btn--block" href={site.phoneHref}>{c.callButtonLabel}</a>
      </div>

      <div class="contact__form">
        <LeadForm formName="contact" heading={c.form.heading} intro={c.form.intro} scheduling={false} cta={c.form.cta} />
      </div>
    </div>
  </section>
</Base>

<style>
  .contact{ display:grid; grid-template-columns:.85fr 1.15fr; gap:clamp(28px,4vw,52px); align-items:start; }
  @media (max-width:860px){ .contact{ grid-template-columns:1fr; } }
  .contact__block{ padding-bottom:1.2rem; margin-bottom:1.2rem; border-bottom:1px solid var(--line); }
  .contact__block h3{ font-size:1.05rem; margin-bottom:.4rem; }
  .contact__phone{ font-size:1.8rem; font-weight:800; color:var(--navy); letter-spacing:-.02em; display:block; }
  .contact__hours{ list-style:none; padding:0; margin:0; font-size:.92rem; }
  .contact__hours li{ display:flex; justify-content:space-between; padding:.3rem 0; border-bottom:1px solid var(--line-2); }
  .contact__hours b{ color:var(--navy); }
</style>
