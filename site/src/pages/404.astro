---
import Base from '@/layouts/Base.astro';
import { site } from '@/data/site';
import { page } from '@/lib/pages';

const c = page('not-found');
---
<Base title={c.meta.title} description={c.meta.description} noindex={true}>
  <section class="section center nf">
    <div class="wrap measure" style="margin-inline:auto;">
      <p class="nf__code">{c.code}</p>
      <h1>{c.heading}</h1>
      <p class="lead" style="margin:.8rem auto 1.6rem;">{c.text}</p>
      <div class="cta-row cta-row--center">
        <a href="/" class="btn btn--lg">{c.homeLabel}</a>
        <a href="/services" class="btn btn--lg btn--outline">{c.servicesLabel}</a>
        <a href={site.phoneHref} class="btn btn--lg btn--navy">{c.callLabel}</a>
      </div>
    </div>
  </section>
</Base>

<style>
  .nf{ padding-block:clamp(60px,9vw,110px); }
  .nf__code{ font-size:clamp(3.5rem,12vw,6rem); font-weight:800; color:var(--gold); line-height:1; letter-spacing:-.04em; margin:0; }
</style>
