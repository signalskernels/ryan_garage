---
import Base from '@/layouts/Base.astro';
import { site } from '@/data/site';
---
<Base title="Page Not Found" description="That page couldn’t be found." noindex={true}>
  <section class="section center nf">
    <div class="wrap measure" style="margin-inline:auto;">
      <p class="nf__code">404</p>
      <h1>We couldn’t find that page</h1>
      <p class="lead" style="margin:.8rem auto 1.6rem;">It may have moved. Let’s get you back on track — or just give us a call.</p>
      <div class="cta-row cta-row--center">
        <a href="/" class="btn btn--lg">Back to home</a>
        <a href="/services" class="btn btn--lg btn--outline">Our services</a>
        <a href={site.phoneHref} class="btn btn--lg btn--navy">Call {site.phone}</a>
      </div>
    </div>
  </section>
</Base>

<style>
  .nf{ padding-block:clamp(60px,9vw,110px); }
  .nf__code{ font-size:clamp(3.5rem,12vw,6rem); font-weight:800; color:var(--gold); line-height:1; letter-spacing:-.04em; margin:0; }
</style>
