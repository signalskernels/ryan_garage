---
import { Image } from 'astro:assets';
import Base from '@/layouts/Base.astro';
import PageHeader from '@/components/PageHeader.astro';
import CtaBand from '@/components/CtaBand.astro';
import { site } from '@/data/site';
import { photo } from '@/lib/photos';
import { page } from '@/lib/pages';

const c = page('visualizer');
---
<Base title={c.meta.title} description={c.meta.description}>
  <PageHeader
    title={c.header.title}
    subtitle={c.header.subtitle}
    crumbs={[{ label: c.header.crumb }]}
  />

  <section class="section">
    <div class="wrap viz">
      <div class="prose">
        <h2>{c.intro.heading}</h2>
        <p>{c.intro.paragraph}</p>
        <ol class="viz__steps">
          {c.steps.map((s: string, i: number) => <li><span>{i + 1}</span>{s}</li>)}
        </ol>
        <div class="cta-row">
          <a href={site.links.visualizer} class="btn btn--lg" target="_blank" rel="noopener">{c.buttons.tool}</a>
          <a href="/book" class="btn btn--lg btn--outline">{c.buttons.quote}</a>
        </div>
        <p class="muted" style="font-size:.84rem; margin-top:1rem;">{c.note}</p>
      </div>
      <div class="viz__media">
        <Image src={photo(c.image.src)} alt={c.image.alt} widths={[420, 640]} sizes="(max-width:800px) 100vw, 420px" />
      </div>
    </div>
  </section>

  <CtaBand title={c.cta.title} text={c.cta.text} />
</Base>

<style>
  .viz{ display:grid; grid-template-columns:1.1fr .9fr; gap:clamp(28px,4vw,52px); align-items:center; }
  @media (max-width:860px){ .viz{ grid-template-columns:1fr; } }
  .viz__media :global(img){ width:100%; border-radius:var(--radius-lg); box-shadow:var(--shadow); }
  .viz__steps{ list-style:none; padding:0; margin:1.2rem 0 1.6rem; }
  .viz__steps li{ display:flex; align-items:center; gap:.8rem; margin:.6rem 0; font-weight:600; color:var(--ink); }
  .viz__steps span{ flex:none; width:28px; height:28px; border-radius:50%; background:var(--gold); color:var(--navy-900);
    font-weight:800; display:flex; align-items:center; justify-content:center; font-size:.85rem; }
</style>
