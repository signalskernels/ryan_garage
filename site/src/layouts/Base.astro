---
import '@/styles/global.css';
import Seo from '@/components/Seo.astro';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import CallBar from '@/components/CallBar.astro';
import Chat from '@/components/Chat.astro';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  jsonLd?: Record<string, any>[];
  noindex?: boolean;
  /** Hide the top emergency/offer ribbon (e.g. on landing-style pages) */
  ribbon?: boolean;
}
const { title, description, image, jsonLd, noindex, ribbon = true } = Astro.props;
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="theme-color" content="#0f2c54" />
  <link rel="icon" type="image/png" href="/favicon.png" />
  <link rel="preload" href="/fonts/inter-700.woff2" as="font" type="font/woff2" crossorigin />
  <link rel="preload" href="/fonts/inter-400.woff2" as="font" type="font/woff2" crossorigin />
  <Seo title={title} description={description} image={image} jsonLd={jsonLd} noindex={noindex} />
</head>
<body>
  <Header ribbon={ribbon} />
  <main id="main">
    <slot />
  </main>
  <Footer />
  <CallBar />
  <Chat />
  <script>
    import '../scripts/leadforms.ts';
  </script>
</body>
</html>
